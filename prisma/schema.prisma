generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  reports   Report[]
}

model Report {
  id        String        @id @default(cuid())
  userId    String
  s3Url     String
  s3Key     String
  filename  String
  fileType  String
  fileSize  Int
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    ReportChunk[]

  @@index([userId])
}

model ReportChunk {
  id        String                      @id @default(cuid())
  reportId  String
  content   String                      @db.Text
  embedding Unsupported("vector(768)")? // Gemini embeddings are 768-dim
  createdAt DateTime                    @default(now())
  report    Report                      @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}
